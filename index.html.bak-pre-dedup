function openSell(idx){S.sellTarget=idx;S.sellWhy='';document.querySelectorAll('.why-tag').forEach(t=>t.classList.remove('selected'));const pos=S.pos[idx];document.getElementById('sell-title').textContent='Sell '+pos.t;document.getElementById('sell-shares').value=pos.s;document.getElementById('sell-price').value=pos.cur||pos.p;document.getElementById('sell-err').style.display='none';document.getElementById('m-sell').style.display='flex';}
function selWhy(btn,why){document.querySelectorAll('.why-tag').forEach(t=>t.classList.remove('selected'));btn.classList.add('selected');S.sellWhy=why;}
function confirmSell(){const shares=parseFloat(document.getElementById('sell-shares').value);const price=parseFloat(document.getElementById('sell-price').value);if(isNaN(shares)||isNaN(price)){document.getElementById('sell-err').style.display='block';return;}const pos=S.pos[S.sellTarget];const pnl=(price-pos.p)*shares;S.realised+=pnl;localStorage.setItem('ti72_realised',S.realised.toString());S.hist.unshift({type:'SELL',t:pos.t,shares,price,pnl:pnl.toFixed(0),why:S.sellWhy||'No reason tagged',date:new Date().toLocaleDateString()});if(shares>=pos.s)S.pos.splice(S.sellTarget,1);else S.pos[S.sellTarget].s-=shares;save();renderPos();cM('m-sell');}

function mirrorTrade(sym,price,reason){const p=parseFloat(price)||0;if(!p){alert('Cannot mirror — no price data');return;}const ex=S.pos.find(x=>x.t===sym);if(ex)ex.s+=1;else S.pos.push({t:sym,s:1,p,cur:p});S.hist.unshift({type:'MIRROR',t:sym,shares:1,price:p,pnl:'0',why:'Mirror: '+reason,date:new Date().toLocaleDateString()});save();renderPos();alert(`Mirrored ${sym} @ $${price} — added to your portfolio tracker.\n\nExecute the actual buy order in your broker.`);}
function paperTrade(sym,price){const p=parseFloat(price)||0;S.paperPos.push({t:sym,p,date:new Date().toLocaleDateString()});S.hist.unshift({type:'PAPER',t:sym,shares:1,price:p,pnl:'0',why:'Paper trade simulation',date:new Date().toLocaleDateString()});localStorage.setItem('ti72_paper',JSON.stringify(S.paperPos));save();renderPaper();}
function renderPaper(){const el=document.getElementById('paper-list');el.innerHTML=S.paperPos.length?S.paperPos.map(p=>`<div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:0.5px solid var(--border);font-size:11px;"><span style="font-family:'DM Mono',monospace;font-weight:600;">${p.t}</span><span style="color:var(--text3);">Paper @ $${p.p} · ${p.date}</span><span class="up">+0.0%</span></div>`).join(''):'<div style="font-size:11px;color:var(--text3);padding:8px 0;">No paper trades yet</div>';}
function togglePaper(){S.paperMode=!S.paperMode;document.getElementById('paper-lbl').textContent=S.paperMode?'On':'Off';}

function addPos(){const t=document.getElementById('f-t').value.toUpperCase().trim();const s=parseFloat(document.getElementById('f-s').value);const p=parseFloat(document.getElementById('f-p').value);if(!t||isNaN(s)||isNaN(p)){alert('Please fill in all three fields');return;}S.pos.push({t,s,p,cur:p});S.hist.unshift({type:'BUY',t,shares:s,price:p,pnl:'0',why:'Manual entry',date:new Date().toLocaleDateString()});save();['f-t','f-s','f-p'].forEach(id=>document.getElementById(id).value='');renderPos();}
function renderPos(){const list=document.getElementById('pos-list'),conc=document.getElementById('conc');if(!S.pos.length){list.innerHTML='<div style="padding:14px 0;text-align:center;color:var(--text3);font-size:12px;">No positions yet</div>';conc.innerHTML='';['r-pos','r-top'].forEach(id=>{const el=document.getElementById(id);if(el){el.textContent='—';el.className='b b-gray';}});['p-val','p-pnl','p-inv'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent='—';});document.getElementById('p-realised').textContent=(S.realised>=0?'+':'')+'$'+S.realised.toFixed(0);renderHist();return;}
const tot=S.pos.reduce((a,p)=>a+p.s*p.cur,0);const sorted=[...S.pos].sort((a,b)=>(b.s*b.cur)-(a.s*a.cur));
list.innerHTML=sorted.map(p=>{const val=p.s*p.cur,cost=p.s*p.p,pnl=val-cost,pct=((pnl/cost)*100).toFixed(1),up=pnl>=0;const ri=S.pos.indexOf(p);return`<div class="pos-row"><div style="flex:1;min-width:0;"><div style="display:flex;align-items:center;gap:7px;margin-bottom:4px;"><span class="pos-tk" onclick="openTicker('${p.t}')">${p.t}</span><span style="font-size:10px;color:var(--text3);">${p.s} shares · avg $${p.p.toFixed(2)}</span></div><div style="display:flex;align-items:center;gap:8px;"><span class="${up?'up':'dn'}" style="font-size:11px;font-weight:600;">${up?'+':''}$${pnl.toFixed(0)} (${up?'+':''}${pct}%)</span><canvas id="spk-${p.t}" width="64" height="22" style="display:block;"></canvas><span style="font-size:10px;color:var(--text3);">$${val.toFixed(0)}</span></div></div><button class="sell-btn" onclick="openSell(${ri})">Sell</button></div>`;}).join('');
setTimeout(()=>{sorted.forEach(p=>{const c=document.getElementById('spk-'+p.t);if(c)drawSparkline(c,genSparkData(p.s*p.cur>=p.s*p.p),p.s*p.cur>=p.s*p.p);});},50);
conc.innerHTML=sorted.slice(0,5).map(p=>{const pct=((p.s*p.cur/tot)*100).toFixed(1),w=Math.min(parseFloat(pct),100);const col=parseFloat(pct)>35?'var(--amber)':parseFloat(pct)>20?'var(--blue)':'var(--green)';return`<div class="mw"><div class="mt2"><span class="ml">${p.t}</span><span class="mv">${pct}%</span></div><div class="mb"><div class="mf" style="width:${w}%;background:${col};"></div></div></div>`;}).join('');
const top3=sorted.slice(0,3).reduce((a,p)=>a+p.s*p.cur,0);const t3p=((top3/tot)*100).toFixed(1),cnt=S.pos.length;const rp=document.getElementById('r-pos');rp.textContent=`${cnt}/12 ${cnt>12?'— Over':'— OK'}`;rp.className=cnt>12?'b b-r':'b b-g';const rt=document.getElementById('r-top');const ok=parseFloat(t3p)>=40&&parseFloat(t3p)<=50;rt.textContent=`${t3p}% — ${ok?'On target':parseFloat(t3p)<40?'Under':'Over'}`;rt.className=ok?'b b-g':'b b-a';
const tv=S.pos.reduce((a,p)=>a+p.s*p.cur,0),tc=S.pos.reduce((a,p)=>a+p.s*p.p,0),tp=tv-tc,tpp=((tp/tc)*100).toFixed(1);document.getElementById('p-val').textContent='$'+tv.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,',');document.getElementById('p-pnl').textContent=(tp>=0?'+':'')+' $'+tp.toFixed(0)+' ('+(tp>=0?'+':'')+tpp+'%)';document.getElementById('p-inv').textContent='$'+tc.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,',');document.getElementById('p-realised').textContent=(S.realised>=0?'+':'')+'$'+S.realised.toFixed(0);renderHist();}

function renderHist(){const el=document.getElementById('trade-hist');if(!S.hist.length){el.innerHTML='<div style="font-size:11px;color:var(--text3);padding:8px 0;">No trades yet</div>';return;}el.innerHTML=S.hist.slice(0,10).map(h=>`<div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:0.5px solid var(--border);font-size:11px;"><span style="width:46px;font-weight:700;font-size:10px;color:${h.type==='SELL'?'var(--red)':h.type==='PAPER'?'var(--blue)':'var(--green)'};">${h.type}</span><span style="font-family:'DM Mono',monospace;font-weight:600;width:44px;">${h.t}</span><span style="flex:1;color:var(--text2);">${h.shares}sh @ $${h.price} · ${h.date}</span>${h.type==='SELL'?`<span style="font-weight:600;color:${parseFloat(h.pnl)>=0?'var(--green)':'var(--red)'};">${parseFloat(h.pnl)>=0?'+':''}$${h.pnl}</span>`:''}<span style="font-size:10px;color:var(--text3);font-style:italic;max-width:90px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${h.why}</span></div>`).join('');}

function updateBudget(){S.budget=parseInt(document.getElementById('budget-slider').value);document.getElementById('budget-display').textContent='$'+S.budget.toLocaleString();document.getElementById('core-amt').textContent='$'+Math.round(S.budget*0.4);document.getElementById('trend-amt').textContent='$'+Math.round(S.budget*0.4);document.getElementById('risk-amt').textContent='$'+Math.round(S.budget*0.2);const weights=[{id:'alloc-asml',w:.29},{id:'alloc-nvda',w:.21},{id:'alloc-rklb',w:.17},{id:'alloc-pltr',w:.17},{id:'alloc-cash',w:.16}];weights.forEach(w=>{const el=document.getElementById(w.id);if(el)el.textContent='$'+Math.round(S.budget*w.w);});}

function gT(n,btn){if(n!=='ticker')S.prevTab=n;document.querySelectorAll('.sec').forEach(s=>s.classList.remove('active'));document.querySelectorAll('.nt').forEach(t=>t.classList.remove('active'));const el=document.getElementById('tab-'+n);if(el)el.classList.add('active');if(btn)btn.classList.add('active');}
function needPin(t,btn){S.pTab=t;S.pBtn=btn;if(!S.pin){alert('Set a PIN first using the button in the top-right corner');return;}if(S.unlocked){gT(t,btn);return;}document.getElementById('pe').value='';document.getElementById('pe-err').style.display='none';document.getElementById('m-pe').style.display='flex';}
function checkPin(){if(document.getElementById('pe').value===S.pin){S.unlocked=true;cM('m-pe');gT(S.pTab,S.pBtn);}else document.getElementById('pe-err').style.display='block';}
function showPinSetup(){document.getElementById('p1').value='';document.getElementById('p2').value='';document.getElementById('p-err').style.display='none';document.getElementById('m-ps').style.display='flex';}
function savePin(){const a=document.getElementById('p1').value,b=document.getElementById('p2').value;if(a.length<4||a!==b){document.getElementById('p-err').style.display='block';return;}S.pin=a;localStorage.setItem('ti72_pin',a);document.getElementById('pinLbl').textContent='Change PIN';cM('m-ps');}
function showAPI(){document.getElementById('av-in').value=S.av||'';document.getElementById('av-err').style.display='none';document.getElementById('m-api').style.display='flex';}
function saveAV(){const k=document.getElementById('av-in').value.trim();if(k.length<10){document.getElementById('av-err').style.display='block';return;}S.av=k;localStorage.setItem('ti72_av',k);cM('m-api');fetchPrices();}
function cM(id){document.getElementById(id).style.display='none';}
function save(){localStorage.setItem('ti72_pos',JSON.stringify(S.pos));localStorage.setItem('ti72_hist',JSON.stringify(S.hist));}

async function fetchPrices(){if(!S.av)return;const pairs=[['NVDA','t-nvda'],['ASML','t-asml'],['AMD','t-amd'],['META','t-meta'],['SPY','t-spy']];for(const[sym,id]of pairs){try{const r=await fetch(`https://www.alphavantage.co/query?function=GLOBAL_QUOTE&symbol=${sym}&apikey=${S.av}`);const d=await r.json();const q=d['Global Quote'];if(q&&q['05. price']){const p=parseFloat(q['05. price']).toFixed(2);const c=parseFloat(q['10. change percent']).toFixed(2);const up=parseFloat(c)>=0;document.getElementById(id).innerHTML=`<span class="${up?'up':'dn'}">$${p} (${up?'+':''}${c}%)</span>`;}}catch(e){console.log('Price fetch failed',sym);}await new Promise(r=>setTimeout(r,420));}}

window.addEventListener('DOMContentLoaded',()=>{if(S.pin)document.getElementById('pinLbl').textContent='Change PIN';renderWL();renderPos();renderPaper();renderMarkets();updateBudget();if(S.av)fetchPrices();});
</script>
</body>
</html>
