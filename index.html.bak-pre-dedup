async function fetchPrices(){
  if(!S.av)return;
  const pairs=[['NVDA','t-nvda'],['ASML','t-asml'],['AMD','t-amd'],['META','t-meta'],['SPY','t-spy']];
  for(const[sym,id]of pairs){
    try{
      const r=await fetch('https://www.alphavantage.co/query?function=GLOBAL_QUOTE&symbol='+sym+'&apikey='+S.av);
      const d=await r.json();const q=d['Global Quote'];
      if(q&&q['05. price']){const p=parseFloat(q['05. price']).toFixed(2),c=parseFloat(q['10. change percent']).toFixed(2),up=parseFloat(c)>=0;document.getElementById(id).innerHTML='<span class="'+(up?'up':'dn')+'">$'+p+' ('+(up?'+':'')+c+'%)</span>';}
