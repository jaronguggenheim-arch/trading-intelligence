  const top3=sorted.slice(0,3).reduce((a,p)=>a+p.s*p.cur,0),t3p=((top3/tot)*100).toFixed(1),cnt=S.pos.length;
  const rp=document.getElementById('r-pos');rp.textContent=`${cnt}/12 ${cnt>12?'OVER':'OK'}`;rp.className=cnt>12?'b b-r':'b b-g';
  const rt=document.getElementById('r-top');const ok=parseFloat(t3p)>=40&&parseFloat(t3p)<=50;rt.textContent=`${t3p}% ${ok?'On target':parseFloat(t3p)<40?'Under':'Over'}`;rt.className=ok?'b b-g':'b b-a';
  const tv=S.pos.reduce((a,p)=>a+p.s*p.cur,0),tc=S.pos.reduce((a,p)=>a+p.s*p.p,0),tp=tv-tc,tpp=((tp/tc)*100).toFixed(1);
  document.getElementById('p-val').textContent='$'+tv.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,',');
  document.getElementById('p-pnl').textContent=(tp>=0?'+':'')+' $'+tp.toFixed(0)+' ('+(tp>=0?'+':'')+tpp+'%)';
  document.getElementById('p-inv').textContent='$'+tc.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,',');
  document.getElementById('p-realised').textContent=(S.realised>=0?'+':'')+'$'+S.realised.toFixed(0);
