# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/trading_intelligence?sslmode=require"

# ── Upstash Redis (KV cache) ───────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# ── NextAuth ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-domain.com"

# ── Google OAuth (for login) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Stripe (paid tier) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."               # $19/month recurring price ID
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ── Data APIs ──────────────────────────────────────────────────────────────────
FINNHUB_API_KEY="your-finnhub-key"
TWELVEDATA_API_KEY="your-twelvedata-key"

# ── Web Push / VAPID ──────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:your@email.com"

# ── Cron auth ─────────────────────────────────────────────────────────────────
CRON_SECRET="random-secret-for-cron-route-protection"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"
